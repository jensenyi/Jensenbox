{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Packet",
  "type": "object",
  "required": ["run_id", "core_judgment", "input_assessment", "opportunities", "sources"],
  "properties": {
    "run_id": { "type": "string" },
    "core_judgment": { "type": "string", "minLength": 20 },
    "input_assessment": { "type": "array", "minItems": 7 },
    "opportunities": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": ["opportunity_id", "signal", "core_fact", "source_urls", "business_mechanism", "why_for_dachuan", "suggested_angle", "asset_potential", "priority"],
        "properties": {
          "opportunity_id": { "type": "string" },
          "signal": { "type": "string" },
          "core_fact": { "type": "string" },
          "source_urls": { "type": "array", "items": { "type": "string" } },
          "business_mechanism": { "type": "string" },
          "why_for_dachuan": { "type": "string" },
          "suggested_angle": { "type": "string" },
          "target_audience": { "type": "string" },
          "asset_potential": { "type": "string" },
          "risk_or_uncertainty": { "type": "string" },
          "priority": { "enum": ["P0", "P1", "P2"] }
        }
      }
    },
    "sources": { "type": "array" },
    "unverified_items": { "type": "array" }
  }
}
